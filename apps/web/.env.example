# ─────────────────────────────────────────────────────────────────
# FrudgeCare web app — env template
# Copy to apps/web/.env.local and fill in values.
# ─────────────────────────────────────────────────────────────────

# Supabase (optional — only needed if you want the persistence path).
# Without these, the app still runs in demo mode using mock data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Demo mode toggle. KEEP THIS TRUE for the hackathon submission — it tells
# proxy.ts to skip every auth gate so judges can hit /triage and /console
# without signing in.
NEXT_PUBLIC_DEMO_MODE=true

# JWT secret used by the (currently bypassed) auth flow. Any random string.
JWT_SECRET=change-me-in-production

# FastAPI AI engine endpoints. The engine binds to :8001 by default.
# On Windows we sometimes hit a stuck bind on :8001 after a crashed
# uvicorn auto-reload — uncomment the :8002 lines below if that happens.
AI_ENGINE_URL=http://localhost:8001/analyze-intake
AI_ENGINE_BASE_URL=http://localhost:8001
NEXT_PUBLIC_AI_ENGINE_URL=http://localhost:8001
# AI_ENGINE_URL=http://localhost:8002/analyze-intake
# AI_ENGINE_BASE_URL=http://localhost:8002
# NEXT_PUBLIC_AI_ENGINE_URL=http://localhost:8002

# Shared secret between Next.js routes and FastAPI. Any random string,
# but it must match services/ai-engine/.env INTERNAL_API_SECRET.
INTERNAL_API_SECRET=change-me-in-production
