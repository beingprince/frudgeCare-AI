# ─────────────────────────────────────────────────────────────────
# FrudgeCare AI engine — env template
# Copy to services/ai-engine/.env and fill in values.
# ─────────────────────────────────────────────────────────────────

# Google Gemini API key. Get one at https://aistudio.google.com/apikey.
# OPTIONAL — without it the cascade still runs end-to-end, it just stops at
# Tier 1 (RAG + NLP) and shows the lower tier badge in the UI. Demo never
# breaks if this is missing.
GEMINI_API_KEY=

# Optional: pin the Gemini model. We default to gemini-2.5-flash-lite because
# the free tier quota for that model is significantly higher than -flash and
# is enough for an entire demo session.
# GEMINI_MODEL=gemini-2.5-flash-lite

# Shared secret with the Next.js web tier. Must match
# apps/web/.env.local INTERNAL_API_SECRET.
INTERNAL_API_SECRET=change-me-in-production
