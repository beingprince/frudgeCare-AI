# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage/

# Next.js build output
.next/
out/

# Production builds
build/
dist/

# OS / editor noise
.DS_Store
Thumbs.db
*.pem
*.swp
.idea/
.vscode/*
!.vscode/settings.json

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Env files (real secrets) — only .env.example ships
.env
.env.local
.env.development
.env.production
.env*.local
!.env.example
!**/.env.example

# Vercel
.vercel

# TypeScript scratch
*.tsbuildinfo
next-env.d.ts

# Python (services/ai-engine)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Synthea raw bundle extraction (large, regenerable from the public zip).
# The curated slim summaries in synthea/sample_patients/ ARE committed.
services/ai-engine/synthea/_extracted/

# Local notebooks and scratch files
*.bak
*.tmp
*.local.*
.scratch/
