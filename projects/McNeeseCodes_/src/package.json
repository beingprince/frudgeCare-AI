{
  "name": "frudge-care-ai-root",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:ai": "cd services/ai-engine && python -m uvicorn main:app --reload --port 8002",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:ai\"",
    "build": "npm run build -w apps/web",
    "lint": "npm run lint -w apps/web"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
