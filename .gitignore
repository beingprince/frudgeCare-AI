# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (root and every workspace)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# Next.js — root and every workspace
.next/
out/

# production
build/
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — block real secrets, allow templates
.env
.env.local
.env.development
.env.production
.env*.local
# DO ship .env.example so collaborators / judges can bootstrap.
!.env.example
!**/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python (services/ai-engine)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE / OS noise
.idea/
.vscode/*
!.vscode/settings.json
.DS_Store
Thumbs.db
*.swp

# Local logs and scratch
*.log
.scratch/
projects/*/build/
projects/*/dist/

# Uvicorn detached log from the smoke test runner
.uvicorn.log
.uvicorn.err.log

# Comment extraction scratch scripts (kept locally, not for the hackathon repo)
apply-comment-strategy.js
extract_comments.js
paraphrase-comments.js

# Internal design and audit notes (not part of the public submission)
documents/

# Local notebooks and scratch files
*.bak
*.tmp
*.local.*
